{
  "name": "cropsly-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-End test suite for Cropsly.com",
  "main": "index.js",
  "scripts": {
    "test:e2e": "cypress run --headless",
    "test:e2e:headed": "cypress run --headed",
    "test:e2e:chrome": "cypress run --browser chrome",
    "test:e2e:firefox": "cypress run --browser firefox",
    "test:e2e:edge": "cypress run --browser edge",
    "test:e2e:single": "cypress run --spec",
    "test:e2e:record": "cypress run --record",
    "test:open": "cypress open",
    "test:report": "node generate-report.js",
    "test:all": "npm run test:e2e && npm run test:report"
  },
  "keywords": [
    "cypress",
    "e2e",
    "testing",
    "cropsly"
  ],
  "author": "Sharma Shekhar",
  "license": "MIT",
  "devDependencies": {
    "cypress": "^13.6.2",
    "cypress-mochawesome-reporter": "^3.8.0",
    "mochawesome": "^7.1.3"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "dotenv": "^16.3.1"
  }
}
